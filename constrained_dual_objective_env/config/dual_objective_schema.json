{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dual Objective Config",
  "type": "object",
  "properties": {
    "weights": {
      "type": "object",
      "properties": {
        "constitutional": {"type": "number", "minimum": 0},
        "needle": {"type": "number", "minimum": 0}
      },
      "required": ["constitutional", "needle"]
    },
    "hard_fail_penalty": {"type": "number", "minimum": 0, "maximum": 1}
  },
  "required": ["weights", "hard_fail_penalty"]
}
