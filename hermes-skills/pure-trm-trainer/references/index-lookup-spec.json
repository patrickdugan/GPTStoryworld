{
  "run_id": "index_lookup_trm_v1",
  "trainer_recipe": "persistent_tesseract_qlora",
  "base_model": "Qwen/Qwen2.5-1.5B-Instruct",
  "corpus_builder_script": "hermes-skills/pure-trm-trainer/scripts/build_router_index_corpus.py",
  "source_json": "storyworlds/charter_of_ashen_aegis.json",
  "messages_jsonl": "hermes-skills/pure-trm-trainer/runs/index_lookup_v1/router_messages.jsonl",
  "output_dir": "hermes-skills/pure-trm-trainer/runs/index_lookup_v1/adapter",
  "train_hparams": {
    "max_steps": 300,
    "seq_len": 1024,
    "batch_size": 1,
    "lr": 0.0002,
    "grad_accum": 16,
    "lora_r": 32,
    "lora_alpha": 64,
    "target_modules": "q_proj,k_proj,v_proj,o_proj",
    "streaming": false
  },
  "router_schema": {
    "intent": "index_retrieval",
    "namespaces": ["constitutions", "characters", "history", "geography", "mechanics"],
    "tools": ["get_encounter_card", "query_lore_index"]
  }
