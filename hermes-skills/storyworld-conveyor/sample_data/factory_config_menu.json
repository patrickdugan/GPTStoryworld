    {
      "id": "desirability_grind",
      "description": "Rewrite desirability/effect scripts across an already-built world and run quality checks.",
      "required_args": ["--base-world", "--out-config"],
      "supports": [
        "--characters",
        "--ending-count",
        "--secret-ending-count",
        "--super-secret-count",
