    },
    {
      "id": "balanced_secret_topology",
      "description": "Fresh build plus path probing, Monte Carlo, reachability rebalance, and optional QLoRA export.",
      "required_args": ["--base-world", "--out-config", "--title", "--about", "--motif"],
      "supports": [
        "--target-encounters",
        "--characters",
        "--ending-count",
        "--secret-ending-count",
        "--super-secret-count",
        "--avg-options",
        "--avg-reactions",
        "--avg-effects",
        "--gate-pct",
        "--mc-runs",
        "--probe-runs",
        "--include-qlora"
      ]
