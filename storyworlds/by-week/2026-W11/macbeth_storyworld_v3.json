  "encounters": [
    {
      "id": "enc_macbeth_prophecy",
      "text_script": {
        "script_element_type": "Pointer",
        "pointer_type": "String",
        "value": "When shall we three meet again? In thunder, lightning, or in rain?"
      },
      "options": [
        {
          "id": "opt_heath",
          "text_script": {
            "script_element_type": "Pointer",
            "pointer_type": "String",
            "value": "Upon the heath, amid this storm"
          },
          "effects": [
            {
              "id": "e_show_prophecy",
              "text_script": {
                "script_element_type": "Pointer",
                "pointer_type": "String",
                "value": "Macbeth shall be king, but Banquo's issue shall reign forever!"
              }
            }
          ]
        }
      ],
      "reactions": []
    },
    {
      "id": "enc_macbeth_decision",
      "text_script": {
        "script_element_type": "Pointer",
        "pointer_type": "String",
        "value": "The prophecy haunts me - shall we act or wait?"
      },
      "options": [
        {
          "id": "opt_act",
          "text_script": {
            "script_element_type": "Pointer",
            "pointer_type": "String",
            "value": "Take fate into our hands - Duncan must fall tonight"
          },
          "effects": [
            {
              "id": "e_ambition_path",
              "text_script": {
                "script_element_type": "Pointer",
                "pointer_type": "String",
                "value": "Ambition consumes us - the path to kingship begins now"
              }
            }
          ]
        },
        {
          "id": "opt_wait",
          "text_script": {
            "script_element_type": "Pointer",
            "pointer_type": "String",
            "value": "Wait for fate to unfold - let prophecy take its course"
          },
          "effects": [
            {
              "id": "e_patience_path",
              "text_script": {
                "script_element_type": "Pointer",
                "pointer_type": "String",
                "value": "Honor prevails - though kingship may never come"
              }
            }
          ]
        }
      ],
      "reactions": []
    }
  ],
