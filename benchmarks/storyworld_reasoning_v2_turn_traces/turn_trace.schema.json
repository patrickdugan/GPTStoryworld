{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "storyworld_reasoning_v2.turn_trace",
  "title": "Storyworld Reasoning Benchmark v2 Turn Trace Row",
  "type": "object",
  "required": [
    "benchmark_id",
    "slice_id",
    "world_id",
    "episode_id",
    "turn_index",
    "acting_agent",
    "visible_state",
    "legal_actions",
    "chosen_action",
    "reasoning_trace",
    "trace_mode",
    "forecasts",
    "confidence",
    "hidden_state_reveal",
    "realized_outcome",
    "belief_delta",
    "score"
  ],
  "properties": {
    "benchmark_id": {
      "type": "string"
    },
    "slice_id": {
      "type": "string"
    },
    "world_id": {
      "type": "string"
    },
    "episode_id": {
      "type": "string"
    },
    "turn_index": {
      "type": "integer",
      "minimum": 1
    },
    "acting_agent": {
      "type": "string"
    },
    "visible_state": {
      "type": "object",
      "required": ["visibility_mode", "active_node", "beliefs", "coalitions", "world_vars", "messages"],
      "properties": {
        "visibility_mode": {
          "type": "string"
        },
        "active_node": {
          "type": ["string", "null"]
        },
        "beliefs": {
          "type": "object"
        },
        "coalitions": {
          "type": "array"
        },
        "world_vars": {
          "type": "object"
        },
        "messages": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "legal_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "target"],
        "properties": {
          "type": {
            "type": "string"
          },
          "target": {
            "type": ["string", "null"]
          }
        },
        "additionalProperties": true
      }
    },
    "chosen_action": {
      "type": "object"
    },
    "reasoning_trace": {
      "type": "string"
    },
    "trace_mode": {
      "type": "string",
      "const": "pick_time"
    },
    "forecasts": {
      "type": "array"
    },
    "confidence": {
      "type": "object"
    },
    "hidden_state_reveal": {
      "type": "array"
    },
    "realized_outcome": {
      "type": "object",
      "required": ["outcome", "active_node_after", "done", "metrics"],
      "properties": {
        "outcome": {
          "type": ["string", "null"]
        },
        "active_node_after": {
          "type": ["string", "null"]
        },
        "done": {
          "type": "boolean"
        },
        "metrics": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "belief_delta": {
      "type": "object",
      "required": ["before", "after"],
      "properties": {
        "before": {
          "type": "object"
        },
        "after": {
          "type": "object"
        }
      },
      "additionalProperties": true
    },
    "score": {
      "type": "object",
      "required": ["action_legality", "forecast"],
      "properties": {
        "action_legality": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0
        },
        "forecast": {}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
