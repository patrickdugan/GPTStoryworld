(= (apply-action (arrest $guard $suspect))
   (match &self (arrest-ready $guard $suspect)
     (match &self (norm-violation $suspect theft $event)
       (do
         (remove-atom &self (at $suspect Market))
         (add-atom &self (at $suspect Jail))
         (add-atom &self (event-kind (arrest-event $guard $suspect) arrest))
         (add-atom &self (event-actor (arrest-event $guard $suspect) $guard))
         (add-atom &self (event-target (arrest-event $guard $suspect) $suspect))
         (add-atom &self (event-place (arrest-event $guard $suspect) Jail))))))
