(= (apply-action (buy $buyer $seller $object $payment))
   (do
     (remove-atom &self (owns $seller $object))
     (remove-atom &self (owns $buyer $payment))
     (add-atom &self (owns $buyer $object))
     (add-atom &self (owns $seller $payment))
     (add-atom &self (event-kind (buy-event $buyer $seller $object $payment) buy))
     (add-atom &self (event-actor (buy-event $buyer $seller $object $payment) $buyer))
     (add-atom &self (event-target (buy-event $buyer $seller $object $payment) $seller))
     (add-atom &self (event-object (buy-event $buyer $seller $object $payment) $object))
     (add-atom &self (trust-delta $seller $buyer 0.10 fair-trade))))
