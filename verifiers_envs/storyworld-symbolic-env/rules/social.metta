(= (apply-action (steal $thief $victim $object))
   (do
     (remove-atom &self (owns $victim $object))
     (add-atom &self (owns $thief $object))
     (add-atom &self (event-kind (steal-event $thief $victim $object) steal))
     (add-atom &self (event-actor (steal-event $thief $victim $object) $thief))
     (add-atom &self (event-target (steal-event $thief $victim $object) $victim))
     (add-atom &self (event-object (steal-event $thief $victim $object) $object))
     (add-atom &self (event-place (steal-event $thief $victim $object) Market))
     (add-atom &self (norm-violation $thief theft (steal-event $thief $victim $object)))
     (add-atom &self (trust-delta $victim $thief -0.35 victim-only))))
