{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Needle Pathfinding Attempts",
  "type": "object",
  "properties": {
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "play_index": {"type": "integer", "minimum": 1},
          "ending_id": {"type": "string"},
          "path_notes": {"type": "string"},
          "steps": {"type": "integer", "minimum": 0},
          "terminal_state": {
            "type": "object",
            "additionalProperties": {"type": "number"}
          }
        },
        "required": ["play_index", "ending_id"]
      }
    },
    "target_specs": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "var": {"type": "string"},
            "op": {"type": "string"},
            "threshold": {"type": "number"},
            "weight": {"type": "number"}
          },
          "required": ["var", "op", "threshold"]
        }
      }
    }
  },
  "required": ["attempts"]
}
