{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Constitutional Rubric",
  "type": "object",
  "properties": {
    "dimensions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "weight": {"type": "number", "minimum": 0},
          "priority": {"type": "integer", "minimum": 1},
          "signal_keys": {"type": "array", "items": {"type": "string"}}
        },
        "required": ["name", "weight", "priority", "signal_keys"]
      }
    },
    "hard_constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "description": {"type": "string"},
          "fail_if_key_true": {"type": "string"}
        },
        "required": ["id", "description", "fail_if_key_true"]
      }
    }
  },
  "required": ["dimensions", "hard_constraints"]
}
